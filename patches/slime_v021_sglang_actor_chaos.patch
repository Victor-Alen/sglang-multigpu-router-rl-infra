diff --git a/slime/ray/rollout.py b/slime/ray/rollout.py
index ab76c33..43a897f 100644
--- a/slime/ray/rollout.py
+++ b/slime/ray/rollout.py
@@ -88,6 +88,27 @@ class RolloutManager:
     def get_rollout_engines_and_lock(self):
         return self.rollout_engines, self.rollout_engine_lock, self.num_new_engines
 
+    def fault_recover_rollout_engine(self, rollout_engine_id: int):
+        """Atomically replace a dead rollout engine after an authorized chaos injection."""
+        if os.environ.get("RL_ENABLE_DESTRUCTIVE_CHAOS") != "1":
+            raise PermissionError("RL_ENABLE_DESTRUCTIVE_CHAOS=1 is required")
+        if not 0 <= rollout_engine_id < len(self.rollout_engines):
+            raise ValueError(f"invalid rollout engine id: {rollout_engine_id}")
+        logger.warning("Replacing chaos-killed rollout engine %s", rollout_engine_id)
+        for i in range(
+            rollout_engine_id * self.nodes_per_engine,
+            (rollout_engine_id + 1) * self.nodes_per_engine,
+        ):
+            engine = self.all_rollout_engines[i]
+            if engine is not None:
+                try:
+                    ray.kill(engine)
+                except Exception as exc:
+                    logger.info("Dead rollout engine %s could not be killed again: %s", i, exc)
+            self.all_rollout_engines[i] = None
+        self.num_new_engines = init_rollout_engines(self.args, self.pg, self.all_rollout_engines)
+        return {"engine_id": rollout_engine_id, "new_engines": self.num_new_engines}
+
     def get_num_rollout_per_epoch(self):
         assert self.args.rollout_global_dataset
         return len(self.data_source.dataset) // self.args.rollout_batch_size
